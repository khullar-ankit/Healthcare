   "source": [
    "Prediction distribution: what did Claude actually respond?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Categorize Claude's raw responses\n",
    "categories = []\n",
    "for r in results:\n",
    "    r_lower = r.lower()\n",
    "    if 'positive' in r_lower:\n",
    "        categories.append('Positive')\n",
    "    elif 'negative' in r_lower:\n",
    "        categories.append('Negative')\n",
    "    else:\n",
    "        categories.append('Unclear')\n",
    "\n",
    "labels_cat, counts = np.unique(categories, return_counts=True)\n",
    "colors = {'Positive': '#55a868', 'Negative': '#c44e52', 'Unclear': '#8c8c8c'}\n",
    "bar_colors = [colors.get(l, '#8c8c8c') for l in labels_cat]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 4))\n",
    "ax.bar(labels_cat, counts, color=bar_colors)\n",
    "ax.set_ylabel('Count')\n",
    "ax.set_title('Claude Zero-Shot Response Distribution')\n",
    "for i, (lbl, cnt) in enumerate(zip(labels_cat, counts)):\n",
    "    ax.text(i, cnt + 0.2, str(cnt), ha='center', fontsize=12)\n",
    "plt.tight_layout()\n",
