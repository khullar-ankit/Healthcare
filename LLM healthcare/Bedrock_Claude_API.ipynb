    "**Section 4: Using Bedrock Titan Embeddings for Synergy Prediction**\n",
    "\n",
    "Instead of OpenAI's `text-embedding-ada-002`, we use Amazon Titan Embeddings via Bedrock."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_embeddings_bedrock(texts, model_id='amazon.titan-embed-text-v1'):\n",
    "    \"\"\"Generate embeddings using Amazon Titan Embeddings via Bedrock.\"\"\"\n",
    "    embeddings = []\n",
    "    for text in tqdm(texts):\n",
    "        text = text.replace('\\n', ' ')\n",
    "        response = bedrock.invoke_model(\n",
    "            modelId=model_id,\n",
    "            body=json.dumps({'inputText': text})\n",
    "        )\n",
    "        result = json.loads(response['body'].read())\n",
    "        embeddings.append(result['embedding'])\n",
    "    return np.array(embeddings)"
   ]
  },
