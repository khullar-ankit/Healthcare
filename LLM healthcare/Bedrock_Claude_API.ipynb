   "source": [
    "**Section 3: Batch Evaluation on Endometrium Test Data**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Load the pre-defined train/test split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train indices: [100160, 100161, 100162, 100163, 100164, 100165, 100167, 100168, 100169, 100170, 100171, 100174, 100175, 100176, 100177, 100178, 100180, 100181, 100182, 100183, 100185, 100187, 100188, 100189, 100190, 100191, 100192, 100193, 100196, 100197, 100198, 100200, 100202, 100203, 100204, 100205, 100206, 100207, 100208, 100209, 100211, 100212, 100213, 100214, 100216, 100217, 100218, 100219, 100220, 100221, 100223, 100224, 100225, 100227]\n",
      "Test indices: [100166, 100172, 100173, 100179, 100184, 100186, 100194, 100195, 100199, 100201, 100210, 100215, 100222, 100226]\n"
     ]
    }
   ],
   "source": [
    "with open('train_test_split.json', 'r') as f:\n",
    "    data_split = json.load(f)\n",
    "print('Train indices:', data_split['endometrium']['train'])\n",
    "print('Test indices:', data_split['endometrium']['test'])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Prompt builder dataset class"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "metadata": {},
   "outputs": [],
   "source": [
    "class DrugCombDataset(Dataset):\n",
    "    def __init__(self, df):\n",
    "        self.df = df\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.df)\n",
    "\n",
    "    def __getitem__(self, index):\n",
    "        column_names = [\n",
    "            ('drug_row', 'The first drug is '),\n",
    "            ('drug_col', '. The second drug is '),\n",
    "            ('cell_line_name', '. Cell line is '),\n",
    "            ('tissue_name', '. Tissue is '),\n",
    "            ('ri_row', \". First drug's sensitivity score using relative inhibition is \"),\n",
    "            ('ri_col', \". Second drug's sensitivity score using relative inhibition is \")\n",
    "        ]\n",
    "\n",
    "        x_strs = [f'{col_desc}{self.df.iloc[index][col]}' for col, col_desc in column_names]\n",
    "        x_str = ''.join(x_strs)\n",
    "        x_str = x_str.replace('\\n', '')\n",
    "        x_str = 'Decide in a single word if the synergy of the drug combination in the cell line is positive or not. Synergy score more than or equal 5 means positive and synergy score less than 5 means negative. ' + x_str\n",
    "        x_str = x_str + '. Please decide whether the synergy is positive or negative.'\n",
    "        return x_str"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [],
   "source": [
    "df['ri_row'] = df['ri_row'].astype(int)\n",
    "df['ri_col'] = df['ri_col'].astype(int)\n",
    "df['synergy_class'] = df['synergy_loewe'].apply(lambda x: x > 5).astype(int)\n",
    "\n",
    "test_indices = data_split['endometrium']['test']\n",
    "test_df = df.iloc[test_indices]\n",
    "test_ds = DrugCombDataset(test_df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Run Claude on each test sample (using Claude 3 Haiku for speed/cost, swap to Sonnet if you want)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "100%|██████████| 14/14 [00:29<00:00,  2.11s/it]\n"
     ]
    }
   ],
   "source": [
    "results = []\n",
    "for prompt in tqdm(test_ds):\n",
    "    resp = call_claude(\n",
    "        messages=[{'role': 'user', 'content': prompt}],\n",
    "        model_id='us.anthropic.claude-haiku-4-5-20251001-v1:0',\n",
    "        max_tokens=10\n",
    "    )\n",
    "    results.append(resp.strip())\n",
    "    time.sleep(1)  # rate limiting\n"
   ]
