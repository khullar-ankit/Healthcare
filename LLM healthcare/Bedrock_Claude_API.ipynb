   "source": [
    "# Compute metrics for both approaches\n",
    "zeroshot_auroc = roc_auc_score(zeroshot_labels, zeroshot_pred)\n",
    "zeroshot_auprc = average_precision_score(zeroshot_labels, zeroshot_pred)\n",
    "embed_auroc = roc_auc_score(test_labels, test_pred)\n",
    "embed_auprc = average_precision_score(test_labels, test_pred)\n",
    "\n",
    "methods = ['Claude Zero-Shot', 'Titan Embeddings + LR']\n",
    "aurocs = [zeroshot_auroc, embed_auroc]\n",
    "auprcs = [zeroshot_auprc, embed_auprc]\n",
    "\n",
    "x = np.arange(len(methods))\n",
    "width = 0.3\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "bars1 = ax.bar(x - width/2, aurocs, width, label='AUROC', color='#4C72B0')\n",
    "bars2 = ax.bar(x + width/2, auprcs, width, label='AUPRC', color='#DD8452')\n",
    "\n",
    "# Add value labels on bars\n",
    "for bar in bars1:\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,\n",
    "            f'{bar.get_height():.3f}', ha='center', fontsize=11)\n",
    "for bar in bars2:\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,\n",
    "            f'{bar.get_height():.3f}', ha='center', fontsize=11)\n",
    "\n",
    "ax.set_ylabel('Score')\n",
    "ax.set_title('Model Comparison - Drug Synergy Prediction (Endometrium)')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(methods)\n",
    "ax.set_ylim(0, 1.15)\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
